{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/delete-image", "destination": "/server.js" },
    { "source": "/create-order", "destination": "/server.js" },
    { "source": "/create-subscription", "destination": "/server.js" },
    { "source": "/razorpay-webhook", "destination": "/server.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, OPTIONS, PUT, DELETE"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "X-Requested-With, Content-Type, Accept, Origin, Authorization"
        },
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        }
      ]
    }
  ]
}